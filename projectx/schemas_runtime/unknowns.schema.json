{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unknowns",
  "type": "object",
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "class"],
        "properties": {
          "id": {"type": "string"},
          "question": {"type": "string"},
          "class": {"type": "string", "enum": ["principled", "engineering", "organizational"]},
          "status": {"type": "string", "enum": ["open", "working", "resolved"]}
        }
      }
    }
  }
}
